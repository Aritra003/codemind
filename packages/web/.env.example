# Database — PostgreSQL required for production (Vercel/Supabase/Railway)
# Local dev: use a local Postgres or Supabase connection string
DATABASE_URL="postgresql://user:password@host:5432/stinkit"

# NextAuth.js
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"  # change to https://yourdomain.com in production

# GitHub OAuth (create at https://github.com/settings/developers)
# Required scope: read:user user:email repo
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (create at https://console.cloud.google.com) — optional
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Anthropic API (for Ask, Plan, See features)
ANTHROPIC_API_KEY=""
